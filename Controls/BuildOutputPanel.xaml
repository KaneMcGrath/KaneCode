<UserControl x:Class="KaneCode.Controls.BuildOutputPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Background="{DynamicResource ErrorListBackground}">
        <!-- Header bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource ErrorListHeaderBackground}"
                Padding="8,4">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Clear"
                        Padding="8,2"
                        Margin="4,0,0,0"
                        Click="ClearButton_Click"
                        Background="{DynamicResource PanelSecondaryBackground}"
                        Foreground="{DynamicResource ErrorListHeaderForeground}"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Build Output"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ErrorListHeaderForeground}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="SummaryText"
                               Margin="12,0,0,0"
                               Foreground="{DynamicResource ErrorListForeground}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Output text -->
        <ScrollViewer x:Name="OutputScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Background="{DynamicResource ErrorListBackground}">
            <TextBlock x:Name="OutputText"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="12"
                       Foreground="{DynamicResource ErrorListForeground}"
                       Padding="8,4"
                       TextWrapping="NoWrap" />
        </ScrollViewer>
    </DockPanel>
</UserControl>
