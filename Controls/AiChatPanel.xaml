<UserControl x:Class="KaneCode.Controls.AiChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <DockPanel Background="{DynamicResource AiChatBackground}">

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource AiChatHeaderBackground}"
                Padding="8,4">
            <DockPanel>
                <ComboBox x:Name="ModeSelector"
                          DockPanel.Dock="Left"
                          SelectionChanged="ModeSelector_SelectionChanged"
                          DisplayMemberPath="DisplayName"
                          FontSize="11"
                          MinWidth="80"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          Foreground="{DynamicResource AiChatForeground}"
                          Background="{DynamicResource AiChatInputBackground}"
                          BorderBrush="{DynamicResource AiChatBorder}"
                          BorderThickness="1"
                          ToolTip="AI chat mode">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                                         Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"
                                         Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="{DynamicResource AiChatInputBackground}" />
                            <Setter Property="Foreground" Value="{DynamicResource AiChatForeground}" />
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonMouseOverBackground}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonPressedBackground}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            Margin="0,0,8,0">
                    <ComboBox x:Name="ConversationSelector"
                              SelectionChanged="ConversationSelector_SelectionChanged"
                              DisplayMemberPath="Title"
                              FontSize="11"
                              MinWidth="170"
                              VerticalAlignment="Center"
                              Margin="0,0,6,0"
                              Foreground="{DynamicResource AiChatForeground}"
                              Background="{DynamicResource AiChatInputBackground}"
                              BorderBrush="{DynamicResource AiChatBorder}"
                              BorderThickness="1"
                              ToolTip="Select an AI conversation">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                                             Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"
                                             Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="{DynamicResource AiChatInputBackground}" />
                                <Setter Property="Foreground" Value="{DynamicResource AiChatForeground}" />
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ButtonMouseOverBackground}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ButtonPressedBackground}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                    <Button x:Name="NewConversationButton"
                            Content="New"
                            Click="NewConversationButton_Click"
                            Padding="6,2"
                            FontSize="11"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource AiChatForeground}"
                            Background="{DynamicResource AiChatInputBackground}"
                            BorderBrush="{DynamicResource AiChatBorder}"
                            BorderThickness="1"
                            Cursor="Hand"
                            ToolTip="Start a new AI conversation" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Grid Margin="0,0,6,0">
                        <primitives:ToggleButton x:Name="FormattingOptionsButton"
                                                 Content="🧾 ▾"
                                                 Width="34"
                                                 Height="22"
                                                 Padding="0"
                                                 FontSize="11"
                                                 Foreground="{DynamicResource AiChatForeground}"
                                                 Background="{DynamicResource AiChatInputBackground}"
                                                 BorderBrush="{DynamicResource AiChatBorder}"
                                                 BorderThickness="1"
                                                 Cursor="Hand"
                                                 ToolTip="Formatting options" />
                        <Popup PlacementTarget="{Binding ElementName=FormattingOptionsButton}"
                               Placement="Bottom"
                               HorizontalOffset="0"
                               VerticalOffset="2"
                               IsOpen="{Binding IsChecked, ElementName=FormattingOptionsButton}"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="{DynamicResource AiChatInputBackground}"
                                    BorderBrush="{DynamicResource AiChatBorder}"
                                    BorderThickness="1"
                                    Padding="8,6"
                                    MinWidth="190">
                                <StackPanel>
                                    <CheckBox x:Name="AutoExpandThinkingCheckBox"
                                              Content="Auto expand thinking"
                                              Margin="0,0,0,4"
                                              Foreground="{DynamicResource AiChatForeground}"
                                              ToolTip="Expand thinking sections by default when they are shown." />
                                    <CheckBox x:Name="AutoExpandToolsCheckBox"
                                              Content="Auto expand tools"
                                              Margin="0,0,0,4"
                                              Foreground="{DynamicResource AiChatForeground}"
                                              ToolTip="Expand tool call sections by default when they are shown." />
                                    <CheckBox x:Name="RemoveVerticalWhitespaceCheckBox"
                                              Content="Remove vertical whitespace"
                                              Margin="0,0,0,4"
                                              Foreground="{DynamicResource AiChatForeground}"
                                              ToolTip="Remove empty lines from rendered assistant output to make responses more compact." />
                                    <Separator Margin="0,2,0,6" />
                                    <CheckBox x:Name="RawTextCheckBox"
                                              Content="Raw mode"
                                              Foreground="{DynamicResource AiChatForeground}"
                                              ToolTip="Show raw text sent to and received from the model, without markdown formatting." />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <Grid Margin="0,0,6,0">
                        <primitives:ToggleButton x:Name="SettingsOptionsButton"
                                                 Content="⚙ ▾"
                                                 Width="34"
                                                 Height="22"
                                                 Padding="0"
                                                 FontSize="11"
                                                 Foreground="{DynamicResource AiChatForeground}"
                                                 Background="{DynamicResource AiChatInputBackground}"
                                                 BorderBrush="{DynamicResource AiChatBorder}"
                                                 BorderThickness="1"
                                                 Cursor="Hand"
                                                 ToolTip="AI chat settings" />
                        <Popup PlacementTarget="{Binding ElementName=SettingsOptionsButton}"
                               Placement="Bottom"
                               HorizontalOffset="0"
                               VerticalOffset="2"
                               IsOpen="{Binding IsChecked, ElementName=SettingsOptionsButton}"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="{DynamicResource AiChatInputBackground}"
                                    BorderBrush="{DynamicResource AiChatBorder}"
                                    BorderThickness="1"
                                    Padding="8,6"
                                    MinWidth="170">
                                <StackPanel>
                                    <CheckBox x:Name="DisableStreamingCheckBox"
                                              Content="Disable Streaming"
                                              Foreground="{DynamicResource AiChatForeground}"
                                              ToolTip="Show model replies only after the full response is complete." />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <Button x:Name="ClearButton"
                            Content="Clear"
                            Click="ClearButton_Click"
                            Padding="6,2"
                            FontSize="11"
                            Foreground="{DynamicResource AiChatForeground}"
                            Background="{DynamicResource AiChatInputBackground}"
                            BorderBrush="{DynamicResource AiChatBorder}"
                            BorderThickness="1"
                            Cursor="Hand" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Stats info bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource AiChatHeaderBackground}"
                Padding="8,2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource AiChatBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Orientation="Vertical"
                            Margin="0,0,8,0">
                    <TextBlock x:Name="StatsBar"
                               Text=""
                               FontSize="11"
                               Foreground="{DynamicResource AiChatSecondaryForeground}" />
                    <TextBlock x:Name="ContextWindowBar"
                               Text="window: 0 msgs  •  est: 0/12,000 tok"
                               FontSize="10"
                               Foreground="{DynamicResource AiChatSecondaryForeground}"
                               Margin="0,1,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <ComboBox x:Name="ProviderSelector"
                               VerticalAlignment="Top"
                               FontSize="11"
                               MinWidth="100"
                               DisplayMemberPath="DisplayName"
                               SelectionChanged="ProviderSelector_SelectionChanged"
                               Foreground="{DynamicResource AiChatForeground}"
                               Background="{DynamicResource AiChatInputBackground}"
                               BorderBrush="{DynamicResource AiChatBorder}"
                               BorderThickness="1"
                               Margin="0,0,6,0"
                               ToolTip="Select AI provider">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                                             Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"
                                             Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="{DynamicResource AiChatInputBackground}" />
                                <Setter Property="Foreground" Value="{DynamicResource AiChatForeground}" />
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ButtonMouseOverBackground}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ButtonPressedBackground}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                    <ComboBox x:Name="ModelSelector"
                              VerticalAlignment="Top"
                              FontSize="11"
                              MinWidth="180"
                              SelectionChanged="ModelSelector_SelectionChanged"
                              Foreground="{DynamicResource AiChatForeground}"
                              Background="{DynamicResource AiChatInputBackground}"
                              BorderBrush="{DynamicResource AiChatBorder}"
                              BorderThickness="1"
                              ToolTip="Select a model for the active provider">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                                             Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"
                                             Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="{DynamicResource AiChatInputBackground}" />
                                <Setter Property="Foreground" Value="{DynamicResource AiChatForeground}" />
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ButtonMouseOverBackground}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ButtonPressedBackground}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Reference bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource AiChatInputBackground}"
                Padding="4,3"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource AiChatBorder}">
            <DockPanel>
                <Button x:Name="AddReferenceButton"
                        DockPanel.Dock="Left"
                        Content="&#x1F4CE; Add"
                        Click="AddReferenceButton_Click"
                        Padding="6,2"
                        FontSize="11"
                        Foreground="{DynamicResource AiChatForeground}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center" />
                <WrapPanel x:Name="ReferenceTagsPanel"
                           Orientation="Horizontal"
                           Margin="4,0,0,0" />
            </DockPanel>
        </Border>

        <!-- Input area -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource AiChatInputBackground}"
                Padding="6"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource AiChatBorder}">
            <DockPanel>
                <Button x:Name="SendButton"
                        DockPanel.Dock="Right"
                        Content="Send"
                        Click="SendButton_Click"
                        Padding="12,4"
                        Margin="6,0,0,0"
                        FontSize="12"
                        VerticalAlignment="Bottom"
                        Foreground="{DynamicResource AiChatSendButtonForeground}"
                        Background="{DynamicResource AiChatSendButtonBackground}"
                        BorderThickness="0"
                        Cursor="Hand" />
                <TextBox x:Name="InputBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="13"
                         FontFamily="Segoe UI, Consolas"
                         Foreground="{DynamicResource AiChatForeground}"
                         Background="{DynamicResource AiChatInputBackground}"
                         CaretBrush="{DynamicResource AiChatForeground}"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource AiChatBorder}"
                         Padding="6,4"
                         PreviewKeyDown="InputBox_PreviewKeyDown" TextChanged="InputBox_TextChanged" />
            </DockPanel>
        </Border>

        <!-- Message area (scrollable) -->
        <Grid Background="{DynamicResource AiChatBackground}">
            <ScrollViewer x:Name="MessageScroller"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource AiChatBackground}">
                <ScrollViewer.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Save Conversation..." Click="MessageArea_SaveConversation" />
                    </ContextMenu>
                </ScrollViewer.ContextMenu>
                <StackPanel x:Name="MessagePanel"
                            Margin="0,8,0,8" />
            </ScrollViewer>

            <StackPanel x:Name="PinnedSectionPanel"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Stretch"
                        Margin="0"
                        Panel.ZIndex="1"
                        Visibility="Collapsed" />
        </Grid>
    </DockPanel>
</UserControl>
