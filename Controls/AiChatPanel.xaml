<UserControl x:Class="KaneCode.Controls.AiChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Background="{DynamicResource AiChatBackground}">

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource AiChatHeaderBackground}"
                Padding="8,4">
            <DockPanel>
                <ComboBox x:Name="ModeSelector"
                          DockPanel.Dock="Left"
                          SelectionChanged="ModeSelector_SelectionChanged"
                          DisplayMemberPath="DisplayName"
                          FontSize="11"
                          MinWidth="80"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          Foreground="{DynamicResource AiChatForeground}"
                          Background="{DynamicResource AiChatInputBackground}"
                          BorderBrush="{DynamicResource AiChatBorder}"
                          BorderThickness="1"
                          ToolTip="AI chat mode">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                                         Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"
                                         Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="{DynamicResource AiChatInputBackground}" />
                            <Setter Property="Foreground" Value="{DynamicResource AiChatForeground}" />
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonMouseOverBackground}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonPressedBackground}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <CheckBox x:Name="RawTextCheckBox"
                              Content="Raw"
                              Margin="0,0,8,0"
                              VerticalAlignment="Center"
                              Foreground="{DynamicResource AiChatForeground}"
                              ToolTip="Show raw text sent to and received from the model, without markdown formatting." />
                    <Button x:Name="AiSettingsButton"
                            Content="⚙"
                            Click="AiSettingsButton_Click"
                            Width="24"
                            Height="22"
                            Padding="0"
                            Margin="0,0,6,0"
                            FontSize="11"
                            Foreground="{DynamicResource AiChatForeground}"
                            Background="{DynamicResource AiChatInputBackground}"
                            BorderBrush="{DynamicResource AiChatBorder}"
                            BorderThickness="1"
                            Cursor="Hand"
                            ToolTip="AI Settings" />
                    <Button x:Name="ClearButton"
                            Content="Clear"
                            Click="ClearButton_Click"
                            Padding="6,2"
                            FontSize="11"
                            Foreground="{DynamicResource AiChatForeground}"
                            Background="{DynamicResource AiChatInputBackground}"
                            BorderBrush="{DynamicResource AiChatBorder}"
                            BorderThickness="1"
                            Cursor="Hand" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Stats info bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource AiChatHeaderBackground}"
                Padding="8,2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource AiChatBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Orientation="Vertical"
                            Margin="0,0,8,0">
                    <TextBlock x:Name="StatsBar"
                               Text=""
                               FontSize="11"
                               Foreground="{DynamicResource AiChatSecondaryForeground}" />
                    <TextBlock x:Name="ContextWindowBar"
                               Text="window: 0 msgs  •  est: 0/12,000 tok"
                               FontSize="10"
                               Foreground="{DynamicResource AiChatSecondaryForeground}"
                               Margin="0,1,0,0" />
                </StackPanel>
                <ComboBox x:Name="ProviderSelector"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Right"
                          FontSize="11"
                          MinWidth="100"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="ProviderSelector_SelectionChanged"
                          Foreground="{DynamicResource AiChatForeground}"
                          Background="{DynamicResource AiChatInputBackground}"
                          BorderBrush="{DynamicResource AiChatBorder}"
                          BorderThickness="1"
                          ToolTip="Select AI provider">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                                         Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"
                                         Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="{DynamicResource AiChatInputBackground}" />
                            <Setter Property="Foreground" Value="{DynamicResource AiChatForeground}" />
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonMouseOverBackground}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonPressedBackground}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>
            </Grid>
        </Border>

        <!-- Reference bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource AiChatInputBackground}"
                Padding="4,3"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource AiChatBorder}">
            <DockPanel>
                <Button x:Name="AddReferenceButton"
                        DockPanel.Dock="Left"
                        Content="&#x1F4CE; Add"
                        Click="AddReferenceButton_Click"
                        Padding="6,2"
                        FontSize="11"
                        Foreground="{DynamicResource AiChatForeground}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center" />
                <WrapPanel x:Name="ReferenceTagsPanel"
                           Orientation="Horizontal"
                           Margin="4,0,0,0" />
            </DockPanel>
        </Border>

        <!-- Input area -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource AiChatInputBackground}"
                Padding="6"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource AiChatBorder}">
            <DockPanel>
                <Button x:Name="SendButton"
                        DockPanel.Dock="Right"
                        Content="Send"
                        Click="SendButton_Click"
                        Padding="12,4"
                        Margin="6,0,0,0"
                        FontSize="12"
                        VerticalAlignment="Bottom"
                        Foreground="{DynamicResource AiChatSendButtonForeground}"
                        Background="{DynamicResource AiChatSendButtonBackground}"
                        BorderThickness="0"
                        Cursor="Hand" />
                <TextBox x:Name="InputBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="13"
                         FontFamily="Segoe UI, Consolas"
                         Foreground="{DynamicResource AiChatForeground}"
                         Background="{DynamicResource AiChatInputBackground}"
                         CaretBrush="{DynamicResource AiChatForeground}"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource AiChatBorder}"
                         Padding="6,4"
                         PreviewKeyDown="InputBox_PreviewKeyDown" TextChanged="InputBox_TextChanged" />
            </DockPanel>
        </Border>

        <!-- Message area (scrollable) -->
        <ScrollViewer x:Name="MessageScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{DynamicResource AiChatBackground}">
            <ScrollViewer.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Save Conversation..." Click="MessageArea_SaveConversation" />
                </ContextMenu>
            </ScrollViewer.ContextMenu>
            <StackPanel x:Name="MessagePanel"
                        Margin="8,8,8,8" />
        </ScrollViewer>
    </DockPanel>
</UserControl>
