<UserControl x:Class="KaneCode.Controls.AiChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             xmlns:local="clr-namespace:KaneCode.Controls">
    <UserControl.Resources>
        <local:ModeDropdownTemplateSelector x:Key="ModeDropdownTemplateSelector" />
    </UserControl.Resources>
    <DockPanel Background="{DynamicResource AiChatBackground}">

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource AiChatHeaderBackground}"
                Padding="8,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Margin="0,0,8,0">
                    <ComboBox x:Name="ConversationSelector"
                              SelectionChanged="ConversationSelector_SelectionChanged"
                              DisplayMemberPath="Title"
                              FontSize="11"
                              MinWidth="170"
                              VerticalAlignment="Center"
                              Margin="0,0,6,0"
                              Foreground="{DynamicResource AiChatForeground}"
                              Background="{DynamicResource AiChatInputBackground}"
                              BorderBrush="{DynamicResource AiChatBorder}"
                              BorderThickness="1"
                              ToolTip="Select an AI conversation">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                                             Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"
                                             Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="{DynamicResource AiChatInputBackground}" />
                                <Setter Property="Foreground" Value="{DynamicResource AiChatForeground}" />
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ButtonMouseOverBackground}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ButtonPressedBackground}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                    <Button x:Name="NewConversationButton"
                            Content="New"
                            Click="NewConversationButton_Click"
                            Padding="6,2"
                            FontSize="11"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource AiChatForeground}"
                            Background="{DynamicResource AiChatInputBackground}"
                            BorderBrush="{DynamicResource AiChatBorder}"
                            BorderThickness="1"
                            Cursor="Hand"
                            ToolTip="Start a new AI conversation" />
                </StackPanel>
                <Button x:Name="ClearButton"
                        Grid.Row="0"
                        Grid.Column="1"
                        Content="Clear"
                        Click="ClearButton_Click"
                        Padding="6,2"
                        FontSize="11"
                        Foreground="{DynamicResource AiChatForeground}"
                        Background="{DynamicResource AiChatInputBackground}"
                        BorderBrush="{DynamicResource AiChatBorder}"
                        BorderThickness="1"
                        Cursor="Hand" />
                <DockPanel Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Margin="0,4,0,0">
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal">
                        <ComboBox x:Name="ModeSelector"
                                  SelectionChanged="ModeSelector_SelectionChanged"
                                  ItemTemplateSelector="{StaticResource ModeDropdownTemplateSelector}"
                                  FontSize="11"
                                  MinWidth="80"
                                  VerticalAlignment="Center"
                                  Margin="0,0,6,0"
                                  Foreground="{DynamicResource AiChatForeground}"
                                  Background="{DynamicResource AiChatInputBackground}"
                                  BorderBrush="{DynamicResource AiChatBorder}"
                                  BorderThickness="1"
                                  ToolTip="AI chat mode">
                            <ComboBox.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                                                 Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"
                                                 Color="{Binding Color, Source={DynamicResource AiChatInputBackground}}" />

                                <!-- Data templates for dropdown items -->
                                <DataTemplate x:Key="ModeDropdownModeTemplate">
                                    <TextBlock Text="{Binding Mode.DisplayName}"
                                               FontSize="11"
                                               Foreground="{DynamicResource AiChatForeground}"
                                               Padding="4,2" />
                                </DataTemplate>

                                <DataTemplate x:Key="ModeDropdownPresetTemplate">
                                    <TextBlock Text="{Binding Preset.Name}"
                                               FontSize="11"
                                               Foreground="{DynamicResource AiChatForeground}"
                                               Padding="4,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontStyle" Value="Normal" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Preset.Name}" Value="">
                                                        <Setter Property="FontStyle" Value="Italic" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AiChatSecondaryForeground}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>

                                <DataTemplate x:Key="ModeDropdownHeaderTemplate">
                                    <TextBlock Text="{Binding Text}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AiChatSecondaryForeground}"
                                               Padding="4,6,4,2"
                                               TextTrimming="None" />
                                </DataTemplate>

                                <DataTemplate x:Key="ModeDropdownSeparatorTemplate">
                                    <Separator Margin="4,2,4,2"
                                               Opacity="0.4"
                                               Foreground="{DynamicResource AiChatBorder}" />
                                </DataTemplate>

                                <DataTemplate x:Key="ModeDropdownActionTemplate">
                                    <TextBlock Text="{Binding Text}"
                                               FontSize="11"
                                               FontStyle="Italic"
                                               Foreground="{DynamicResource AiChatSecondaryForeground}"
                                               Padding="4,3" />
                                </DataTemplate>

                                <!-- Base style for ComboBoxItem: non-selectable types are skipped -->
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="{DynamicResource AiChatInputBackground}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AiChatForeground}" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Style.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ButtonMouseOverBackground}" />
                                            <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ButtonPressedBackground}" />
                                            <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                        </Trigger>
                                        <!-- Hide focus visuals and disable interaction for non-selectable items -->
                                        <DataTrigger Binding="{Binding IsSelectable}" Value="False">
                                            <Setter Property="IsEnabled" Value="False" />
                                            <Setter Property="Focusable" Value="False" />
                                            <Setter Property="IsHitTestVisible" Value="False" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Foreground" Value="{DynamicResource AiChatSecondaryForeground}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Resources>
                        </ComboBox>
                        <Grid Margin="0,0,6,0">
                            <primitives:ToggleButton x:Name="SettingsOptionsButton"
                                                     Content="🔧 ▾"
                                                     Width="34"
                                                     Height="22"
                                                     Padding="0"
                                                     FontSize="11"
                                                     Foreground="{DynamicResource AiChatForeground}"
                                                     Background="{DynamicResource AiChatInputBackground}"
                                                     BorderBrush="{DynamicResource AiChatBorder}"
                                                     BorderThickness="1"
                                                     Cursor="Hand"
                                                     ToolTip="Enable/disable individual tools for this conversation" />
                            <Popup PlacementTarget="{Binding ElementName=SettingsOptionsButton}"
                                   Placement="Bottom"
                                   HorizontalOffset="0"
                                   VerticalOffset="2"
                                   IsOpen="{Binding IsChecked, ElementName=SettingsOptionsButton}"
                                   StaysOpen="False"
                                   AllowsTransparency="True">
                                <Border Background="{DynamicResource AiChatInputBackground}"
                                        BorderBrush="{DynamicResource AiChatBorder}"
                                        BorderThickness="1"
                                        Padding="8,6"
                                        MinWidth="280"
                                        MaxHeight="480">
                                    <DockPanel>
                                        <Button x:Name="SystemPromptButton"
                                                DockPanel.Dock="Top"
                                                Content="📝 Edit System Prompt..."
                                                Click="SystemPromptButton_Click"
                                                Padding="6,4"
                                                Margin="0,0,0,6"
                                                FontSize="11"
                                                HorizontalAlignment="Stretch"
                                                Cursor="Hand"
                                                Foreground="{DynamicResource AiChatForeground}"
                                                Background="{DynamicResource AiChatHeaderBackground}"
                                                BorderBrush="{DynamicResource AiChatBorder}"
                                                BorderThickness="1"
                                                ToolTip="Edit the system prompt sent to the model with each request." />
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel x:Name="ToolsCheckboxPanel">
                                                <TextBlock Text="Available Tools"
                                                           FontWeight="SemiBold"
                                                           FontSize="11"
                                                           Margin="0,0,0,4"
                                                           Foreground="{DynamicResource AiChatForeground}" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                            </Popup>
                        </Grid>
                        <Grid>
                            <primitives:ToggleButton x:Name="FormattingOptionsButton"
                                                     Content="🧾 ▾"
                                                     Width="34"
                                                     Height="22"
                                                     Padding="0"
                                                     FontSize="11"
                                                     Foreground="{DynamicResource AiChatForeground}"
                                                     Background="{DynamicResource AiChatInputBackground}"
                                                     BorderBrush="{DynamicResource AiChatBorder}"
                                                     BorderThickness="1"
                                                     Cursor="Hand"
                                                     ToolTip="Formatting options" />
                            <Popup PlacementTarget="{Binding ElementName=FormattingOptionsButton}"
                                   Placement="Bottom"
                                   HorizontalOffset="0"
                                   VerticalOffset="2"
                                   IsOpen="{Binding IsChecked, ElementName=FormattingOptionsButton}"
                                   StaysOpen="False"
                                   AllowsTransparency="True">
                                <Border Background="{DynamicResource AiChatInputBackground}"
                                        BorderBrush="{DynamicResource AiChatBorder}"
                                        BorderThickness="1"
                                        Padding="8,6"
                                        MinWidth="190">
                                    <StackPanel>
                                        <CheckBox x:Name="AutoExpandThinkingCheckBox"
                                                  Content="Auto expand thinking"
                                                  Margin="0,0,0,4"
                                                  Foreground="{DynamicResource AiChatForeground}"
                                                  ToolTip="Expand thinking sections by default when they are shown." />
                                        <CheckBox x:Name="AutoExpandToolsCheckBox"
                                                  Content="Auto expand tools"
                                                  Margin="0,0,0,4"
                                                  Foreground="{DynamicResource AiChatForeground}"
                                                  ToolTip="Expand tool call sections by default when they are shown." />
                                        <CheckBox x:Name="RemoveVerticalWhitespaceCheckBox"
                                                  Content="Remove vertical whitespace"
                                                  IsChecked="True"
                                                  Margin="0,0,0,4"
                                                  Foreground="{DynamicResource AiChatForeground}"
                                                  ToolTip="Remove empty lines from rendered assistant output to make responses more compact." />
                                        <Separator Margin="0,2,0,6" />
                                        <CheckBox x:Name="RawTextCheckBox"
                                                  Content="Raw mode"
                                                  Foreground="{DynamicResource AiChatForeground}"
                                                  ToolTip="Show the raw JSON request payload sent to the API, including system prompt, conversation messages, tool definitions, and inference parameters." />
                                        <CheckBox x:Name="DisableStreamingCheckBox"
                                                  Content="Disable Streaming"
                                                  Margin="0,4,0,0"
                                                  Foreground="{DynamicResource AiChatForeground}"
                                                  ToolTip="Show model replies only after the full response is complete." />
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>
                    <primitives:ToggleButton DockPanel.Dock="Right"
                                             x:Name="ModelPickerButton"
                                             Padding="6,2"
                                             MinWidth="120"
                                             MaxWidth="260"
                                             MinHeight="22"
                                             Margin="8,0,0,0"
                                             FontSize="11"
                                             VerticalAlignment="Center"
                                             Foreground="{DynamicResource AiChatForeground}"
                                             Background="{DynamicResource AiChatInputBackground}"
                                             BorderBrush="{DynamicResource AiChatBorder}"
                                             BorderThickness="1"
                                             Cursor="Hand"
                                             ToolTip="Select provider and model"
                                             IsChecked="False"
                                             Click="ModelPickerButton_Click" />
                </DockPanel>
            </Grid>
        </Border>

        <!-- Stats info bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource AiChatHeaderBackground}"
                Padding="8,2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource AiChatBorder}">
            <StackPanel Orientation="Vertical">
                <TextBlock x:Name="StatsBar"
                           Text=""
                           FontSize="11"
                           Foreground="{DynamicResource AiChatSecondaryForeground}" />
                <TextBlock x:Name="ContextWindowBar"
                           Text="window: 0 msgs  •  est: 0/12,000 tok"
                           FontSize="10"
                           Foreground="{DynamicResource AiChatSecondaryForeground}"
                           Margin="0,1,0,0" />
            </StackPanel>
        </Border>

        <!-- Reference bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource AiChatInputBackground}"
                Padding="4,3"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource AiChatBorder}">
            <DockPanel>
                <Button x:Name="AddReferenceButton"
                        DockPanel.Dock="Left"
                        Content="&#x1F4CE; Add"
                        Click="AddReferenceButton_Click"
                        Padding="6,2"
                        FontSize="11"
                        Foreground="{DynamicResource AiChatForeground}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center" />
                <Button x:Name="PasteImageButton"
                        DockPanel.Dock="Left"
                        Content="&#x1F5BC;&#xFE0F; Paste"
                        Click="PasteImageButton_Click"
                        Padding="6,2"
                        Margin="4,0,0,0"
                        FontSize="11"
                        Foreground="{DynamicResource AiChatForeground}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        ToolTip="Paste an image from the clipboard as vision context for the next message." />
                <WrapPanel x:Name="ReferenceTagsPanel"
                           Orientation="Horizontal"
                           Margin="4,0,0,0" />
            </DockPanel>
        </Border>

        <!-- Input area -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource AiChatInputBackground}"
                Padding="6,6"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource AiChatBorder}">
            <Grid x:Name="InputPanelContainer">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Textbox fills column 0 (spanning both rows so buttons sit flush to its right) -->
                <TextBox x:Name="InputBox"
                         Grid.Column="0"
                         Grid.RowSpan="2"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="120"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="13"
                         FontFamily="Segoe UI, Consolas"
                         Foreground="{DynamicResource AiChatForeground}"
                         Background="{DynamicResource AiChatInputBackground}"
                         CaretBrush="{DynamicResource AiChatForeground}"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource AiChatBorder}"
                         Padding="6,4"
                         SpellCheck.IsEnabled="True"
                         Language="en-US"
                         PreviewKeyDown="InputBox_PreviewKeyDown"
                         TextChanged="InputBox_TextChanged"
                         ContextMenuOpening="InputBox_ContextMenuOpening" />

                <!-- Expand button at top of column 1, left-aligned to sit against the textbox edge -->
                <Button x:Name="ExpandButton"
                        Grid.Column="1"
                        Grid.Row="0"
                        Content="⛶"
                        Click="ExpandButton_Click"
                        FontSize="12"
                        Padding="1,0"
                        Width="20"
                        Height="18"
                        Margin="4,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="{DynamicResource AiChatForeground}"
                        Background="{DynamicResource AiChatInputBackground}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource AiChatBorder}"
                        Cursor="Hand"
                        ToolTip="Open expanded input window" />

                <!-- Send button at bottom of column 1 -->
                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Grid.Row="1"
                        Content="Send"
                        Click="SendButton_Click"
                        Padding="12,4"
                        Margin="6,0,0,0"
                        FontSize="12"
                        VerticalAlignment="Bottom"
                        Foreground="{DynamicResource AiChatSendButtonForeground}"
                        Background="{DynamicResource AiChatSendButtonBackground}"
                        BorderThickness="0"
                        Cursor="Hand" />
            </Grid>
        </Border>

        <!-- Message area (scrollable) -->
        <Grid Background="{DynamicResource AiChatBackground}">
            <ScrollViewer x:Name="MessageScroller"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource AiChatBackground}">
                <ScrollViewer.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Save Conversation..." Click="MessageArea_SaveConversation" />
                    </ContextMenu>
                </ScrollViewer.ContextMenu>
                <StackPanel x:Name="MessagePanel"
                            Margin="0,8,0,8" />
            </ScrollViewer>

            <StackPanel x:Name="PinnedSectionPanel"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Stretch"
                        Margin="0"
                        Panel.ZIndex="1"
                        Visibility="Collapsed" />

            <!-- Model/Provider picker overlay -->
            <Border x:Name="ModelPickerOverlay"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Stretch"
                    Height="280"
                    Panel.ZIndex="2"
                    Visibility="Collapsed"
                    Background="{DynamicResource AiChatInputBackground}"
                    BorderBrush="{DynamicResource AiChatBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="0"
                    MouseDown="ModelPickerOverlay_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Provider"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AiChatSecondaryForeground}"
                               Padding="8,6,4,4" />
                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Text="Model"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AiChatSecondaryForeground}"
                               Padding="4,6,8,4" />
                    <ListBox x:Name="ProviderListBox"
                             Grid.Row="1"
                             Grid.Column="0"
                             DisplayMemberPath="DisplayName"
                             FontSize="11"
                             Foreground="{DynamicResource AiChatForeground}"
                             Background="Transparent"
                             BorderThickness="0,0,1,0"
                             BorderBrush="{DynamicResource AiChatBorder}"
                             SelectionChanged="ProviderListBox_SelectionChanged"
                             Padding="4,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ButtonMouseOverBackground}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ButtonPressedBackground}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Resources>
                    </ListBox>
                    <ListBox x:Name="ModelListBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             FontSize="11"
                             Foreground="{DynamicResource AiChatForeground}"
                             Background="Transparent"
                             BorderThickness="0"
                             SelectionChanged="ModelListBox_SelectionChanged"
                             Padding="4,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ButtonMouseOverBackground}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ButtonPressedBackground}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AiChatSendButtonForeground}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Resources>
                    </ListBox>
                    <!-- Close button at bottom right -->
                    <Button Grid.Row="2"
                            Grid.Column="1"
                            x:Name="ModelPickerCloseButton"
                            Content="✕ Close"
                            Click="ModelPickerCloseButton_Click"
                            Padding="8,3"
                            Margin="0,4,6,4"
                            FontSize="11"
                            HorizontalAlignment="Right"
                            Cursor="Hand"
                            Foreground="{DynamicResource AiChatForeground}"
                            Background="{DynamicResource AiChatInputBackground}"
                            BorderBrush="{DynamicResource AiChatBorder}"
                            BorderThickness="1" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
