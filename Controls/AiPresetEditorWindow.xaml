<Window x:Class="KaneCode.Controls.AiPresetEditorWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preset Editor"
        Width="680"
        Height="560"
        MinWidth="520"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top: Preset selector + rename -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Preset:"
                       FontWeight="SemiBold"
                       FontSize="12"
                       Foreground="{DynamicResource EditorForeground}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />

            <ComboBox Grid.Row="0" Grid.Column="1"
                      x:Name="PresetSelector"
                      DisplayMemberPath="Name"
                      MinHeight="24"
                      FontSize="12"
                      Foreground="{DynamicResource EditorForeground}"
                      Background="{DynamicResource EditorBackground}"
                      BorderBrush="{DynamicResource EditorBorder}"
                      SelectionChanged="PresetSelector_SelectionChanged"
                      ToolTip="Select an existing preset or create a new one">
                <ComboBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                                     Color="{Binding Color, Source={DynamicResource EditorBackground}}" />
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="{DynamicResource EditorBackground}" />
                        <Setter Property="Foreground" Value="{DynamicResource EditorForeground}" />
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonMouseOverBackground}" />
                                <Setter Property="Foreground" Value="{DynamicResource EditorForeground}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Resources>
            </ComboBox>

            <StackPanel Grid.Row="0" Grid.Column="2"
                        Orientation="Horizontal"
                        Margin="8,0,0,0">
                <Button x:Name="NewPresetButton"
                        Content="New"
                        Padding="10,3"
                        MinHeight="24"
                        FontSize="11"
                        Margin="0,0,4,0"
                        Cursor="Hand"
                        Click="NewPresetButton_Click"
                        Foreground="{DynamicResource EditorForeground}"
                        Background="{DynamicResource EditorBackground}"
                        BorderBrush="{DynamicResource EditorBorder}"
                        BorderThickness="1" />
                <Button x:Name="DeletePresetButton"
                        Content="Delete"
                        Padding="10,3"
                        MinHeight="24"
                        FontSize="11"
                        Cursor="Hand"
                        Click="DeletePresetButton_Click"
                        Foreground="{DynamicResource EditorForeground}"
                        Background="{DynamicResource EditorBackground}"
                        BorderBrush="{DynamicResource EditorBorder}"
                        BorderThickness="1" />
            </StackPanel>

            <!-- Preset name field -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="Name:"
                       FontSize="11"
                       Foreground="{DynamicResource EditorForeground}"
                       VerticalAlignment="Center"
                       Margin="0,6,8,0" />

            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                     x:Name="PresetNameBox"
                     MinHeight="22"
                     FontSize="12"
                     Margin="0,6,0,0"
                     Foreground="{DynamicResource EditorForeground}"
                     Background="{DynamicResource EditorBackground}"
                     BorderBrush="{DynamicResource EditorBorder}"
                     BorderThickness="1"
                     TextChanged="PresetNameBox_TextChanged"
                     ToolTip="Display name for this preset in the mode dropdown" />
        </Grid>

        <!-- Middle: System prompt and tools -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="200" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="System Prompt:"
                       FontWeight="SemiBold"
                       FontSize="11"
                       Foreground="{DynamicResource EditorForeground}"
                       Margin="0,0,0,3" />

            <TextBox Grid.Row="1"
                     x:Name="SystemPromptBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="12"
                     FontFamily="Consolas"
                     Foreground="{DynamicResource EditorForeground}"
                     Background="{DynamicResource EditorBackground}"
                     BorderBrush="{DynamicResource EditorBorder}"
                     BorderThickness="1"
                     Padding="4"
                     TextChanged="SystemPromptBox_TextChanged"
                     ToolTip="Custom system prompt sent to the model. Leave empty to use the default mode prompt." />

            <TextBlock Grid.Row="2"
                       Text="Allowed Tools (unchecked = tool is disabled for this preset):"
                       FontWeight="SemiBold"
                       FontSize="11"
                       Foreground="{DynamicResource EditorForeground}"
                       Margin="0,8,0,3" />

            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,0,4">
                <StackPanel x:Name="ToolsPanel" />
            </ScrollViewer>
        </Grid>

        <!-- Bottom: buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button x:Name="SaveButton"
                    Content="Save"
                    Padding="14,6"
                    MinWidth="80"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Margin="0,0,8,0"
                    Cursor="Hand"
                    Click="SaveButton_Click"
                    Foreground="{DynamicResource EditorForeground}"
                    Background="{DynamicResource ButtonPrimaryBackground}"
                    BorderBrush="{DynamicResource ButtonPrimaryBorder}"
                    BorderThickness="1"
                    IsEnabled="False" />
            <Button Content="Cancel"
                    Padding="14,6"
                    MinWidth="80"
                    FontSize="12"
                    Cursor="Hand"
                    Click="CancelButton_Click"
                    Foreground="{DynamicResource EditorForeground}"
                    Background="{DynamicResource EditorBackground}"
                    BorderBrush="{DynamicResource EditorBorder}"
                    BorderThickness="1" />
        </StackPanel>
    </Grid>
</Window>
