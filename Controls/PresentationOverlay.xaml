<UserControl x:Class="KaneCode.Controls.PresentationOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Bottom"
             Margin="16,0,16,12">
    <UserControl.Resources>
        <DropShadowEffect x:Key="OverlayShadow"
                          BlurRadius="16"
                          ShadowDepth="4"
                          Opacity="0.4"
                          Color="Black" />
    </UserControl.Resources>
    <Border Background="{DynamicResource PanelSecondaryBackground}"
            BorderBrush="{DynamicResource ControlBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,12"
            Effect="{StaticResource OverlayShadow}">
        <DockPanel>
            <!-- Header row: title + close button -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <Button x:Name="CloseButton"
                        DockPanel.Dock="Right"
                        Content="✕"
                        Click="CloseButton_Click"
                        Width="24" Height="24"
                        FontSize="12"
                        Padding="0"
                        Foreground="{DynamicResource PanelForeground}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Top"
                        ToolTip="Close presentation" />
                <TextBlock x:Name="TitleText"
                           Text="Presentation"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PanelHeaderForeground}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </DockPanel>

            <!-- Navigation row: Back / slide counter / Next -->
            <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                <Button x:Name="BackButton"
                        DockPanel.Dock="Left"
                        Content="◀ Back"
                        Click="BackButton_Click"
                        Padding="10,4"
                        FontSize="12"
                        Foreground="{DynamicResource ControlForeground}"
                        Background="{DynamicResource ControlBackground}"
                        BorderBrush="{DynamicResource ControlBorder}"
                        BorderThickness="1"
                        Cursor="Hand" />
                <Button x:Name="NextButton"
                        DockPanel.Dock="Right"
                        Content="Next ▶"
                        Click="NextButton_Click"
                        Padding="10,4"
                        FontSize="12"
                        Foreground="{DynamicResource ControlForeground}"
                        Background="{DynamicResource ControlBackground}"
                        BorderBrush="{DynamicResource ControlBorder}"
                        BorderThickness="1"
                        Cursor="Hand" />
                <TextBlock x:Name="SlideCounter"
                           Text="0 / 0"
                           FontSize="12"
                           Foreground="{DynamicResource PanelForeground}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </DockPanel>

            <!-- Slide content: file info + explanatory text -->
            <StackPanel Margin="0,0,0,0">
                <TextBlock x:Name="FileInfoText"
                           FontSize="11"
                           Foreground="{DynamicResource EditorLineNumbersForeground}"
                           FontFamily="Consolas"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,6" />
                <TextBlock x:Name="SlideText"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Foreground="{DynamicResource PanelForeground}"
                           MaxHeight="200" />
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
