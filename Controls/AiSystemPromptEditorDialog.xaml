<Window x:Class="KaneCode.Controls.AiSystemPromptEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit System Prompt"
        Width="600"
        Height="450"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AiChatBackground}"
        Foreground="{DynamicResource AiChatForeground}">
    <DockPanel Margin="10">
        <TextBlock DockPanel.Dock="Top"
                   Text="System Prompt"
                   FontWeight="SemiBold"
                   FontSize="13"
                   Margin="0,0,0,6"
                   Foreground="{DynamicResource AiChatForeground}" />
        <TextBlock DockPanel.Dock="Top"
                   Text="This message is prepended to every request sent to the model. Editing it will switch to Custom mode."
                   TextWrapping="Wrap"
                   FontSize="11"
                   Margin="0,0,0,8"
                   Foreground="{DynamicResource AiChatSecondaryForeground}" />
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button x:Name="SaveButton"
                    Content="Save"
                    Click="SaveButton_Click"
                    Padding="16,6"
                    Margin="0,0,8,0"
                    FontSize="12"
                    Foreground="{DynamicResource AiChatSendButtonForeground}"
                    Background="{DynamicResource AiChatSendButtonBackground}"
                    BorderThickness="0"
                    Cursor="Hand" />
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Click="CancelButton_Click"
                    Padding="16,6"
                    FontSize="12"
                    Foreground="{DynamicResource AiChatForeground}"
                    Background="{DynamicResource AiChatInputBackground}"
                    BorderBrush="{DynamicResource AiChatBorder}"
                    BorderThickness="1"
                    Cursor="Hand" />
        </StackPanel>
        <TextBox x:Name="PromptTextBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontSize="12"
                 FontFamily="Cascadia Code, Consolas, Courier New"
                 Foreground="{DynamicResource AiChatForeground}"
                 Background="{DynamicResource AiChatInputBackground}"
                 CaretBrush="{DynamicResource AiChatForeground}"
                 BorderBrush="{DynamicResource AiChatBorder}"
                 BorderThickness="1"
                 Padding="6" />
    </DockPanel>
</Window>
