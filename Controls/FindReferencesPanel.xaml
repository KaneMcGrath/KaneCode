<UserControl x:Class="KaneCode.Controls.FindReferencesPanel"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Background="{DynamicResource ErrorListBackground}">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource ErrorListHeaderBackground}"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Find References"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ErrorListHeaderForeground}"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Margin="12,0,0,0"
                           Foreground="{DynamicResource ErrorListForeground}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TreeView x:Name="ReferencesTree"
                      Grid.Row="0"
                      Background="{DynamicResource ErrorListBackground}"
                      BorderThickness="0"
                      Foreground="{DynamicResource ErrorListForeground}"
                      MouseDoubleClick="ReferencesTree_MouseDoubleClick"
                      SelectedItemChanged="ReferencesTree_SelectedItemChanged">
                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="_Go to Reference" Click="ContextMenu_GoToReference" />
                        <MenuItem Header="_Peek Definition" Click="ContextMenu_PeekDefinition" />
                        <Separator />
                        <MenuItem Header="Copy _Path" Click="ContextMenu_CopyPath" />
                        <MenuItem Header="Copy _Line" Click="ContextMenu_CopyLine" />
                    </ContextMenu>
                </TreeView.ContextMenu>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded}" />
                        <Setter Property="Foreground" Value="{DynamicResource ErrorListForeground}" />
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="2,1">
                            <TextBlock Text="{Binding Icon}"
                                       Margin="0,0,6,0"
                                       Foreground="{Binding AccentBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Text}"
                                       Foreground="{DynamicResource ErrorListForeground}" />
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <Border Grid.Row="1"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource ErrorListGridLine}"
                    Background="{DynamicResource ErrorListBackground}"
                    Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding ElementName=Root, Path=PeekHeaderText}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ErrorListHeaderForeground}"
                               Margin="0,0,0,6" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  MinHeight="120"
                                  MaxHeight="220">
                        <TextBox Text="{Binding ElementName=Root, Path=PeekContentText}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource ErrorListForeground}"
                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                 FontSize="13"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="True"
                                 AcceptsTab="True" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
