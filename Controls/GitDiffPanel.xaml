<UserControl x:Class="KaneCode.Controls.GitDiffPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit">
    <DockPanel Background="{DynamicResource ErrorListBackground}">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource ErrorListHeaderBackground}"
                Padding="8,4">
            <TextBlock x:Name="HeaderText"
                       Text="Diff"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ErrorListHeaderForeground}" />
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource PanelSecondaryBackground}" Padding="6,2">
                <TextBlock Text="HEAD" Foreground="{DynamicResource ErrorListHeaderForeground}" FontWeight="SemiBold" />
            </Border>
            <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource PanelSecondaryBackground}" Padding="6,2">
                <TextBlock Text="Working Tree" Foreground="{DynamicResource ErrorListHeaderForeground}" FontWeight="SemiBold" />
            </Border>

            <GridSplitter Grid.Row="1" Grid.Column="1" Width="4" Background="{DynamicResource PanelSecondaryBackground}" />

            <avalonEdit:TextEditor x:Name="LeftEditor"
                                   Grid.Row="1" Grid.Column="0"
                                   IsReadOnly="True"
                                   ShowLineNumbers="True"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="12"
                                   Background="{DynamicResource EditorBackground}"
                                   Foreground="{DynamicResource EditorForeground}"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto" />

            <avalonEdit:TextEditor x:Name="RightEditor"
                                   Grid.Row="1" Grid.Column="2"
                                   IsReadOnly="True"
                                   ShowLineNumbers="True"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="12"
                                   Background="{DynamicResource EditorBackground}"
                                   Foreground="{DynamicResource EditorForeground}"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto" />
        </Grid>
    </DockPanel>
</UserControl>
