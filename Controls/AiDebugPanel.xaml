<UserControl x:Class="KaneCode.Controls.AiDebugPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:KaneCode.Models"
             x:Name="AiDebugRoot">
    <DockPanel Background="{DynamicResource ErrorListBackground}">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource ErrorListHeaderBackground}"
                Padding="8,4">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Clear"
                        Padding="8,2"
                        Margin="4,0,0,0"
                        Click="ClearButton_Click"
                        Background="{DynamicResource PanelSecondaryBackground}"
                        Foreground="{DynamicResource ErrorListHeaderForeground}"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="AI Debug"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ErrorListHeaderForeground}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="SummaryText"
                               Margin="12,0,0,0"
                               Foreground="{DynamicResource ErrorListForeground}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Background="{DynamicResource ErrorListBackground}"
                    BorderThickness="0">
            <TabItem Header="Tool Failures">
                <DataGrid x:Name="ToolFailuresGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource ErrorListGridLine}"
                          Background="{DynamicResource ErrorListBackground}"
                          Foreground="{DynamicResource ErrorListForeground}"
                          RowBackground="{DynamicResource ErrorListBackground}"
                          BorderThickness="0"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True"
                          CanUserReorderColumns="False"
                          PreviewMouseRightButtonDown="ToolFailuresGrid_PreviewMouseRightButtonDown">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Open in text editor"
                                      Click="ContextMenu_OpenInTextEditor" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource ErrorListHeaderBackground}" />
                            <Setter Property="Foreground" Value="{DynamicResource ErrorListHeaderForeground}" />
                            <Setter Property="Padding" Value="6,4" />
                            <Setter Property="BorderBrush" Value="{DynamicResource ErrorListGridLine}" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="4,2" />
                            <Setter Property="Foreground" Value="{DynamicResource ErrorListForeground}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ErrorListSelectedBackground}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{DynamicResource ErrorListBackground}" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ErrorListSelectedBackground}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding TimestampDisplay}" Width="80" />
                        <DataGridTextColumn Header="Tool" Binding="{Binding ToolName}" Width="1.2*" MinWidth="120" />
                        <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="2.6*" MinWidth="220" />
                        <DataGridTextColumn Header="Call Id" Binding="{Binding ToolCallId}" Width="1.2*" MinWidth="120" />
                        <DataGridTemplateColumn Header="Arguments" Width="3.5*" MinWidth="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:AiToolFailureEntry}">
                                    <TextBlock Text="{Binding Arguments}"
                                               TextWrapping="Wrap"
                                               MaxHeight="72"
                                               ToolTip="{Binding Arguments}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
