<Window x:Class="KaneCode.Controls.AiReferencePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Reference" Width="400" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBackground}">
    <DockPanel Margin="8">
        <!-- Search box -->
        <TextBox x:Name="SearchBox"
                 DockPanel.Dock="Top"
                 Margin="0,0,0,8"
                 Padding="6,4"
                 FontSize="13"
                 Foreground="{DynamicResource PanelForeground}"
                 Background="{DynamicResource PanelSecondaryBackground}"
                 BorderBrush="{DynamicResource AiChatBorder}"
                 CaretBrush="{DynamicResource PanelForeground}"
                 TextChanged="SearchBox_TextChanged" />

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="Add" Padding="16,4"
                    Click="AddButton_Click"
                    Foreground="{DynamicResource AiChatSendButtonForeground}"
                    Background="{DynamicResource AiChatSendButtonBackground}"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0" />
            <Button Content="Cancel" Padding="16,4"
                    Click="CancelButton_Click"
                    Foreground="{DynamicResource PanelForeground}"
                    Background="{DynamicResource PanelSecondaryBackground}"
                    BorderThickness="0" Cursor="Hand" />
        </StackPanel>

        <!-- File list -->
        <ListBox x:Name="FileList"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{DynamicResource PanelForeground}"
                 MouseDoubleClick="FileList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" FontSize="12" Margin="2" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
