<Window x:Class="KaneCode.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Options"
        Width="650" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}">
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Category list -->
        <ListBox x:Name="CategoryList"
                 Grid.Column="0"
                 Background="{DynamicResource PanelBackground}"
                 Foreground="{DynamicResource PanelForeground}"
                 BorderThickness="0"
                 Padding="0"
                 SelectionChanged="CategoryList_SelectionChanged"
                 SelectedIndex="0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="12,8" />
                    <Setter Property="Foreground" Value="{DynamicResource PanelForeground}" />
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd"
                                        Background="Transparent"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource OptionsSelectedCategoryBackground}" />
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource OptionsSelectedCategoryForeground}" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource OptionsHoverCategoryBackground}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBoxItem Content="General" />
            <ListBoxItem Content="Appearance" />
            <ListBoxItem Content="Hotkeys" />
            <ListBoxItem Content="AI Settings" />
        </ListBox>

        <!-- Separator -->
        <Border Grid.Column="1" Background="{DynamicResource SplitterBackground}" />

        <!-- General page -->
        <Border Grid.Column="2"
                x:Name="GeneralPageBorder"
                Background="{DynamicResource WindowBackground}"
                Padding="20,16"
                Visibility="Visible">
            <StackPanel>
                <TextBlock Text="General"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource WindowForeground}"
                           Margin="0,0,0,16" />
                <TextBlock Text="No settings available yet."
                           Foreground="{DynamicResource PanelForeground}"
                           FontSize="13" />
            </StackPanel>
        </Border>

        <!-- Appearance page -->
        <Border Grid.Column="2"
                x:Name="AppearancePageBorder"
                Background="{DynamicResource WindowBackground}"
                Padding="20,16"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Appearance"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource WindowForeground}"
                           Margin="0,0,0,16" />

                <TextBlock Text="Theme"
                           Foreground="{DynamicResource WindowForeground}"
                           FontSize="13" FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ComboBox x:Name="ThemeComboBox"
                          Width="200"
                          HorizontalAlignment="Left"
                          SelectionChanged="ThemeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Dark" />
                    <ComboBoxItem Content="Light" />
                    <ComboBoxItem Content="Blue" />
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- AI Providers page -->
        <Border Grid.Column="2"
                x:Name="AiProvidersPageBorder"
                Background="{DynamicResource WindowBackground}"
                Padding="20,16"
                Visibility="Collapsed">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="AI Settings"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource WindowForeground}"
                           Margin="0,0,0,12" />

                <!-- Toolbar -->
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,10">
                    <Button Content="Add"
                            Command="{Binding AddCommand}"
                            Padding="10,4" Margin="0,0,6,0" />
                    <Button Content="Remove"
                            Command="{Binding RemoveCommand}"
                            Padding="10,4" Margin="0,0,6,0" />
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Padding="10,4" Margin="0,0,6,0" />
                </StackPanel>

                <!-- Provider list + detail -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ListBox Grid.Column="0"
                             ItemsSource="{Binding Entries}"
                             SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                             Background="{DynamicResource PanelBackground}"
                             Foreground="{DynamicResource PanelForeground}"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource SplitterBackground}" />

                    <!-- Detail panel -->
                    <Grid Grid.Column="2"
                          x:Name="AiDetailPanel"
                          DataContext="{Binding SelectedEntry}"
                          IsEnabled="False">

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Label" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                         Width="220" HorizontalAlignment="Left" Margin="0,0,0,10" />

                                <TextBlock Text="Provider" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding DataContext.ProviderTypes, RelativeSource={RelativeSource AncestorType=Border}}"
                                          SelectedItem="{Binding ProviderId}"
                                          Width="220" HorizontalAlignment="Left" Margin="0,0,0,10" />

                                <TextBlock Text="Endpoint" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}"
                                         Width="300" HorizontalAlignment="Left" Margin="0,0,0,10" />

                                <TextBlock Text="API Key" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4" />
                                <PasswordBox x:Name="ApiKeyBox" Width="300" HorizontalAlignment="Left" Margin="0,0,0,10"
                                             PasswordChanged="ApiKeyBox_PasswordChanged" />

                                <TextBlock Text="Model" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding SelectedModel, UpdateSourceTrigger=PropertyChanged}"
                                         Width="220" HorizontalAlignment="Left" Margin="0,0,0,10" />

                                <TextBlock Text="Inference Parameters" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowForeground}" Margin="0,4,0,8" />

                                <TextBlock Text="Temperature" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding Temperature, UpdateSourceTrigger=PropertyChanged}"
                                         Width="120" HorizontalAlignment="Left" Margin="0,0,0,10" />

                                <TextBlock Text="Top P" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding TopP, UpdateSourceTrigger=PropertyChanged}"
                                         Width="120" HorizontalAlignment="Left" Margin="0,0,0,10" />

                                <TextBlock Text="Top K" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding TopK, UpdateSourceTrigger=PropertyChanged}"
                                         Width="120" HorizontalAlignment="Left" Margin="0,0,0,10" />

                                <TextBlock Text="Min P" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MinP, UpdateSourceTrigger=PropertyChanged}"
                                         Width="120" HorizontalAlignment="Left" Margin="0,0,0,10" />

                                <TextBlock Text="Presence Penalty" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding PresencePenalty, UpdateSourceTrigger=PropertyChanged}"
                                         Width="120" HorizontalAlignment="Left" Margin="0,0,0,10" />

                                <TextBlock Text="Repetition Penalty" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding RepetitionPenalty, UpdateSourceTrigger=PropertyChanged}"
                                         Width="120" HorizontalAlignment="Left" Margin="0,0,0,10" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </DockPanel>
        </Border>

        <!-- Hotkeys page -->
        <Border Grid.Column="2"
                x:Name="HotkeysPageBorder"
                Background="{DynamicResource WindowBackground}"
                Padding="20,16"
                Visibility="Collapsed">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Hotkeys"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource WindowForeground}"
                           Margin="0,0,0,12" />

                <!-- Toolbar -->
                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            Margin="0,10,0,0">
                    <Button Content="Assign Key"
                            x:Name="AssignKeyButton"
                            Click="AssignKey_Click"
                            Padding="10,4" Margin="0,0,6,0" />
                    <Button Content="Clear"
                            Command="{Binding ClearSelectedCommand}"
                            Padding="10,4" Margin="0,0,6,0" />
                    <Button Content="Reset Selected"
                            Command="{Binding ResetSelectedCommand}"
                            Padding="10,4" Margin="0,0,6,0" />
                    <Button Content="Reset All"
                            Command="{Binding ResetAllCommand}"
                            Padding="10,4" Margin="0,0,6,0" />
                </StackPanel>

                <!-- Recording indicator -->
                <TextBlock DockPanel.Dock="Bottom"
                           x:Name="RecordingIndicator"
                           Text="{Binding RecordingText}"
                           Foreground="{DynamicResource DiagnosticWarningForeground}"
                           FontSize="13" FontWeight="SemiBold"
                           Margin="0,6,0,0"
                           Visibility="Collapsed" />

                <!-- Hotkey list -->
                <ListView x:Name="HotkeyListView"
                          ItemsSource="{Binding Bindings}"
                          SelectedItem="{Binding SelectedBinding, Mode=TwoWay}"
                          Background="{DynamicResource PanelBackground}"
                          Foreground="{DynamicResource PanelForeground}"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource SplitterBackground}"
                          SelectionMode="Single"
                          MouseDoubleClick="HotkeyList_MouseDoubleClick"
                          PreviewKeyDown="HotkeyList_PreviewKeyDown">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Action" Width="200"
                                            DisplayMemberBinding="{Binding DisplayName}" />
                            <GridViewColumn Header="Shortcut" Width="160"
                                            DisplayMemberBinding="{Binding GestureText}" />
                            <GridViewColumn Header="Default" Width="160"
                                            DisplayMemberBinding="{Binding DefaultGestureText}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>
    </Grid>
</Window>
