<Window x:Class="KaneCode.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Options"
        Width="600" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}">
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Category list -->
        <ListBox x:Name="CategoryList"
                 Grid.Column="0"
                 Background="{DynamicResource PanelBackground}"
                 Foreground="{DynamicResource PanelForeground}"
                 BorderThickness="0"
                 Padding="0"
                 SelectionChanged="CategoryList_SelectionChanged"
                 SelectedIndex="0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="12,8" />
                    <Setter Property="Foreground" Value="{DynamicResource PanelForeground}" />
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd"
                                        Background="Transparent"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource OptionsSelectedCategoryBackground}" />
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource OptionsSelectedCategoryForeground}" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource OptionsHoverCategoryBackground}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBoxItem Content="General" />
            <ListBoxItem Content="Appearance" />
            <ListBoxItem Content="Hotkeys" />
        </ListBox>

        <!-- Separator -->
        <Border Grid.Column="1" Background="{DynamicResource SplitterBackground}" />

        <!-- General page -->
        <Border Grid.Column="2"
                x:Name="GeneralPageBorder"
                Background="{DynamicResource WindowBackground}"
                Padding="20,16"
                Visibility="Visible">
            <StackPanel>
                <TextBlock Text="General"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource WindowForeground}"
                           Margin="0,0,0,16" />
                <TextBlock Text="No settings available yet."
                           Foreground="{DynamicResource PanelForeground}"
                           FontSize="13" />
            </StackPanel>
        </Border>

        <!-- Appearance page -->
        <Border Grid.Column="2"
                x:Name="AppearancePageBorder"
                Background="{DynamicResource WindowBackground}"
                Padding="20,16"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Appearance"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource WindowForeground}"
                           Margin="0,0,0,16" />

                <TextBlock Text="Theme"
                           Foreground="{DynamicResource WindowForeground}"
                           FontSize="13" FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ComboBox x:Name="ThemeComboBox"
                          Width="200"
                          HorizontalAlignment="Left"
                          SelectionChanged="ThemeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Dark" />
                    <ComboBoxItem Content="Light" />
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Hotkeys page -->
        <Border Grid.Column="2"
                x:Name="HotkeysPageBorder"
                Background="{DynamicResource WindowBackground}"
                Padding="20,16"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Hotkeys"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource WindowForeground}"
                           Margin="0,0,0,16" />
                <TextBlock Text="No configurable hotkeys yet."
                           Foreground="{DynamicResource PanelForeground}"
                           FontSize="13" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
