<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window / chrome -->
    <SolidColorBrush x:Key="WindowBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="WindowForeground" Color="#D4D4D4" />

    <!-- Menu -->
    <SolidColorBrush x:Key="MenuBackground" Color="#2D2D2D" />
    <SolidColorBrush x:Key="MenuForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="MenuItemHighlight" Color="#094771" />
    <SolidColorBrush x:Key="MenuPopupBackground" Color="#2D2D2D" />
    <SolidColorBrush x:Key="MenuPopupBorder" Color="#3E3E42" />
    <SolidColorBrush x:Key="MenuSeparator" Color="#3E3E42" />
    <SolidColorBrush x:Key="MenuItemDisabledForeground" Color="#656565" />

    <!-- Status bar -->
    <SolidColorBrush x:Key="StatusBarBackground" Color="#007ACC" />
    <SolidColorBrush x:Key="StatusBarForeground" Color="#FFFFFF" />

    <!-- Side panels -->
    <SolidColorBrush x:Key="PanelBackground" Color="#252526" />
    <SolidColorBrush x:Key="PanelForeground" Color="#CCCCCC" />
    <SolidColorBrush x:Key="PanelHeaderForeground" Color="#BBBBBB" />
    <SolidColorBrush x:Key="PanelSecondaryBackground" Color="#2D2D30" />

    <!-- Splitter -->
    <SolidColorBrush x:Key="SplitterBackground" Color="#3E3E42" />

    <!-- Tab strip -->
    <SolidColorBrush x:Key="TabStripBackground" Color="#2D2D2D" />
    <SolidColorBrush x:Key="TabForeground" Color="#969696" />
    <SolidColorBrush x:Key="TabSelectedBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="TabSelectedForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TabCloseButtonForeground" Color="#969696" />
    <SolidColorBrush x:Key="TabCloseButtonHoverBackground" Color="#424245" />

    <!-- Editor -->
    <SolidColorBrush x:Key="EditorBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="EditorForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="EditorLineNumbersForeground" Color="#858585" />
    <SolidColorBrush x:Key="SyntaxDefaultForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="SyntaxKeywordForeground" Color="#569CD6" />
    <SolidColorBrush x:Key="SyntaxCommentForeground" Color="#6A9955" />
    <SolidColorBrush x:Key="SyntaxStringForeground" Color="#CE9178" />
    <SolidColorBrush x:Key="SyntaxNumberForeground" Color="#B5CEA8" />
    <SolidColorBrush x:Key="SyntaxPreprocessorForeground" Color="#C586C0" />
    <SolidColorBrush x:Key="SyntaxTypeForeground" Color="#4EC9B0" />

    <!-- TreeView -->
    <SolidColorBrush x:Key="TreeViewItemSelectedBackground" Color="#094771" />
    <SolidColorBrush x:Key="TreeViewItemSelectedForeground" Color="#FFFFFF" />

    <!-- Roslyn semantic classification -->
    <SolidColorBrush x:Key="RoslynTypeForeground" Color="#4EC9B0" />
    <SolidColorBrush x:Key="RoslynInterfaceForeground" Color="#B8D7A3" />
    <SolidColorBrush x:Key="RoslynEnumForeground" Color="#B8D7A3" />
    <SolidColorBrush x:Key="RoslynEnumMemberForeground" Color="#4FC1FF" />
    <SolidColorBrush x:Key="RoslynDelegateForeground" Color="#4EC9B0" />
    <SolidColorBrush x:Key="RoslynTypeParameterForeground" Color="#B8D7A3" />
    <SolidColorBrush x:Key="RoslynMethodForeground" Color="#DCDCAA" />
    <SolidColorBrush x:Key="RoslynPropertyForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="RoslynEventForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="RoslynFieldForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="RoslynParameterForeground" Color="#9CDCFE" />
    <SolidColorBrush x:Key="RoslynLocalForeground" Color="#9CDCFE" />
    <SolidColorBrush x:Key="RoslynNamespaceForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="RoslynControlKeywordForeground" Color="#C586C0" />
    <SolidColorBrush x:Key="RoslynStringEscapeForeground" Color="#D7BA7D" />
    <SolidColorBrush x:Key="RoslynOperatorOverloadForeground" Color="#DCDCAA" />
    <SolidColorBrush x:Key="RoslynLabelForeground" Color="#D4D4D4" />

    <!-- Diagnostics -->
    <SolidColorBrush x:Key="DiagnosticErrorForeground" Color="#F44747" />
    <SolidColorBrush x:Key="DiagnosticWarningForeground" Color="#CCA700" />
    <SolidColorBrush x:Key="DiagnosticInfoForeground" Color="#75BEFF" />

    <!-- Completion popup -->
    <SolidColorBrush x:Key="CompletionBackground" Color="#252526" />
    <SolidColorBrush x:Key="CompletionForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="CompletionSelectedBackground" Color="#094771" />
    <SolidColorBrush x:Key="CompletionBorder" Color="#3E3E42" />

    <!-- Options window -->
    <SolidColorBrush x:Key="OptionsSelectedCategoryBackground" Color="#094771" />
    <SolidColorBrush x:Key="OptionsSelectedCategoryForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="OptionsHoverCategoryBackground" Color="#2A2D2E" />

    <!-- Quick Info tooltip -->
    <SolidColorBrush x:Key="TooltipBackground" Color="#2D2D30" />
    <SolidColorBrush x:Key="TooltipForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="TooltipBorder" Color="#3E3E42" />

    <!-- Error list panel -->
    <SolidColorBrush x:Key="ErrorListBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ErrorListForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="ErrorListHeaderBackground" Color="#2D2D2D" />
    <SolidColorBrush x:Key="ErrorListHeaderForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="ErrorListSelectedBackground" Color="#094771" />
    <SolidColorBrush x:Key="ErrorListGridLine" Color="#3E3E42" />

    <!-- AI Chat panel -->
    <SolidColorBrush x:Key="AiChatBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="AiChatForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="AiChatSecondaryForeground" Color="#808080" />
    <SolidColorBrush x:Key="AiChatHeaderBackground" Color="#2D2D2D" />
    <SolidColorBrush x:Key="AiChatHeaderForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="AiChatBorder" Color="#3E3E42" />
    <SolidColorBrush x:Key="AiChatInputBackground" Color="#252526" />
    <SolidColorBrush x:Key="AiChatUserBubble" Color="#264F78" />
    <SolidColorBrush x:Key="AiChatUserForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AiChatAssistantBubble" Color="#2D2D30" />
    <SolidColorBrush x:Key="AiChatAssistantForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="AiChatCodeBlockBackground" Color="#1A1A1A" />
    <SolidColorBrush x:Key="AiChatCodeForeground" Color="#CE9178" />
    <SolidColorBrush x:Key="AiChatSendButtonBackground" Color="#0E639C" />
    <SolidColorBrush x:Key="AiChatSendButtonForeground" Color="#FFFFFF" />

</ResourceDictionary>
