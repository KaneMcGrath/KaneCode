<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window / chrome -->
    <SolidColorBrush x:Key="WindowBackground" Color="#F3F3F3" />
    <SolidColorBrush x:Key="WindowForeground" Color="#1E1E1E" />

    <!-- Menu -->
    <SolidColorBrush x:Key="MenuBackground" Color="#E8E8E8" />
    <SolidColorBrush x:Key="MenuForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="MenuItemHighlight" Color="#BF3000" />
    <SolidColorBrush x:Key="MenuPopupBackground" Color="#F0F0F0" />
    <SolidColorBrush x:Key="MenuPopupBorder" Color="#CCCCCC" />
    <SolidColorBrush x:Key="MenuSeparator" Color="#D0D0D0" />
    <SolidColorBrush x:Key="MenuItemDisabledForeground" Color="#A0A0A0" />

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonMouseOverBackground" Color="#BF3000" />
    <SolidColorBrush x:Key="ButtonPressedBackground" Color="#9B2400" />
    <SolidColorBrush x:Key="ButtonPressedForeground" Color="#FFFFFF" />

    <!-- Inputs / common controls -->
    <SolidColorBrush x:Key="ControlBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ControlForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ControlBorder" Color="#CCCCCC" />
    <SolidColorBrush x:Key="ControlDisabledForeground" Color="#A0A0A0" />
    <SolidColorBrush x:Key="ControlHoverBackground" Color="#EFEFEF" />
    <SolidColorBrush x:Key="ControlSelectionBackground" Color="#BF3000" />
    <SolidColorBrush x:Key="ControlSelectionForeground" Color="#FFFFFF" />

    <!-- Status bar -->
    <SolidColorBrush x:Key="StatusBarBackground" Color="#BF3000" />
    <SolidColorBrush x:Key="StatusBarForeground" Color="#FFFFFF" />

    <!-- Side panels -->
    <SolidColorBrush x:Key="PanelBackground" Color="#F0F0F0" />
    <SolidColorBrush x:Key="PanelForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="PanelHeaderForeground" Color="#333333" />
    <SolidColorBrush x:Key="PanelSecondaryBackground" Color="#D0D0D0" />

    <!-- Splitter -->
    <SolidColorBrush x:Key="SplitterBackground" Color="#CCCCCC" />

    <!-- Tab strip -->
    <SolidColorBrush x:Key="TabStripBackground" Color="#ECECEC" />
    <SolidColorBrush x:Key="TabForeground" Color="#555555" />
    <SolidColorBrush x:Key="TabSelectedBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TabSelectedForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="TabCloseButtonForeground" Color="#555555" />
    <SolidColorBrush x:Key="TabCloseButtonHoverBackground" Color="#DADADA" />

    <!-- Editor -->
    <SolidColorBrush x:Key="EditorBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="EditorForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="EditorLineNumbersForeground" Color="#2B91AF" />
    <SolidColorBrush x:Key="SyntaxDefaultForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="SyntaxKeywordForeground" Color="#0000FF" />
    <SolidColorBrush x:Key="SyntaxCommentForeground" Color="#008000" />
    <SolidColorBrush x:Key="SyntaxStringForeground" Color="#A31515" />
    <SolidColorBrush x:Key="SyntaxNumberForeground" Color="#098658" />
    <SolidColorBrush x:Key="SyntaxPreprocessorForeground" Color="#AF00DB" />
    <SolidColorBrush x:Key="SyntaxTypeForeground" Color="#267F99" />

    <!-- TreeView -->
    <SolidColorBrush x:Key="TreeViewItemSelectedBackground" Color="#BF3000" />
    <SolidColorBrush x:Key="TreeViewItemSelectedForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="TreeViewItemMouseOverBackground" Color="#E0E0E0" />

    <!-- Roslyn semantic classification -->
    <SolidColorBrush x:Key="RoslynTypeForeground" Color="#267F99" />
    <SolidColorBrush x:Key="RoslynInterfaceForeground" Color="#267F99" />
    <SolidColorBrush x:Key="RoslynEnumForeground" Color="#267F99" />
    <SolidColorBrush x:Key="RoslynEnumMemberForeground" Color="#0070C1" />
    <SolidColorBrush x:Key="RoslynDelegateForeground" Color="#267F99" />
    <SolidColorBrush x:Key="RoslynTypeParameterForeground" Color="#267F99" />
    <SolidColorBrush x:Key="RoslynMethodForeground" Color="#795E26" />
    <SolidColorBrush x:Key="RoslynPropertyForeground" Color="#001080" />
    <SolidColorBrush x:Key="RoslynEventForeground" Color="#001080" />
    <SolidColorBrush x:Key="RoslynFieldForeground" Color="#001080" />
    <SolidColorBrush x:Key="RoslynParameterForeground" Color="#001080" />
    <SolidColorBrush x:Key="RoslynLocalForeground" Color="#001080" />
    <SolidColorBrush x:Key="RoslynNamespaceForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="RoslynControlKeywordForeground" Color="#AF00DB" />
    <SolidColorBrush x:Key="RoslynStringEscapeForeground" Color="#EE0000" />
    <SolidColorBrush x:Key="RoslynOperatorOverloadForeground" Color="#795E26" />
    <SolidColorBrush x:Key="RoslynLabelForeground" Color="#1E1E1E" />

    <!-- Diagnostics -->
    <SolidColorBrush x:Key="DiagnosticErrorForeground" Color="#E51400" />
    <SolidColorBrush x:Key="DiagnosticWarningForeground" Color="#BF8803" />
    <SolidColorBrush x:Key="DiagnosticInfoForeground" Color="#1A85FF" />

    <!-- Git status badges -->
    <SolidColorBrush x:Key="GitModifiedForeground" Color="#A26B00" />
    <SolidColorBrush x:Key="GitAddedForeground" Color="#107C10" />
    <SolidColorBrush x:Key="GitUntrackedForeground" Color="#666666" />
    <SolidColorBrush x:Key="GitDeletedForeground" Color="#C50F1F" />
    <SolidColorBrush x:Key="GitConflictForeground" Color="#D83B01" />

    <!-- Completion popup -->
    <SolidColorBrush x:Key="CompletionBackground" Color="#F3F3F3" />
    <SolidColorBrush x:Key="CompletionForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="CompletionSelectedBackground" Color="#BF3000" />
    <SolidColorBrush x:Key="CompletionBorder" Color="#CCCCCC" />

    <!-- Options window -->
    <SolidColorBrush x:Key="OptionsSelectedCategoryBackground" Color="#BF3000" />
    <SolidColorBrush x:Key="OptionsSelectedCategoryForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="OptionsHoverCategoryBackground" Color="#E0E0E0" />

    <!-- Quick Info tooltip -->
    <SolidColorBrush x:Key="TooltipBackground" Color="#F6F6F6" />
    <SolidColorBrush x:Key="TooltipForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="TooltipBorder" Color="#CCCCCC" />

    <!-- Error list panel -->
    <SolidColorBrush x:Key="ErrorListBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ErrorListForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ErrorListHeaderBackground" Color="#E8E8E8" />
    <SolidColorBrush x:Key="ErrorListHeaderForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ErrorListSelectedBackground" Color="#BF3000" />
    <SolidColorBrush x:Key="ErrorListGridLine" Color="#CCCCCC" />

    <!-- AI Chat panel -->
    <SolidColorBrush x:Key="AiChatBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AiChatForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="AiChatSecondaryForeground" Color="#6E6E6E" />
    <SolidColorBrush x:Key="AiChatHeaderBackground" Color="#E8E8E8" />
    <SolidColorBrush x:Key="AiChatHeaderForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="AiChatBorder" Color="#CCCCCC" />
    <SolidColorBrush x:Key="AiChatInputBackground" Color="#F6F6F6" />
    <SolidColorBrush x:Key="AiChatUserBubble" Color="#BF3000" />
    <SolidColorBrush x:Key="AiChatUserForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AiChatAssistantBubble" Color="#F0F0F0" />
    <SolidColorBrush x:Key="AiChatAssistantForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="AiChatCodeBlockBackground" Color="#E8E8E8" />
    <SolidColorBrush x:Key="AiChatCodeForeground" Color="#A31515" />
    <SolidColorBrush x:Key="AiChatSendButtonBackground" Color="#BF3000" />
    <SolidColorBrush x:Key="AiChatSendButtonForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AiChatThinkingBackground" Color="#FFF0EB" />
    <SolidColorBrush x:Key="AiChatThinkingForeground" Color="#BF3000" />
    <SolidColorBrush x:Key="AiChatThinkingBorder" Color="#FFD4C2" />
    <SolidColorBrush x:Key="AiChatRefTagBackground" Color="#FFE5E0" />
    <SolidColorBrush x:Key="AiChatRefTagForeground" Color="#BF3000" />

    <!-- AI Chat tool-call blocks -->
    <SolidColorBrush x:Key="AiChatToolCallBackground" Color="#EFF5FB" />
    <SolidColorBrush x:Key="AiChatToolCallBorder" Color="#B0C4DE" />
    <SolidColorBrush x:Key="AiChatToolCallForeground" Color="#2C3E50" />
    <SolidColorBrush x:Key="AiChatToolCallSuccessForeground" Color="#16A085" />
    <SolidColorBrush x:Key="AiChatToolCallErrorForeground" Color="#C0392B" />

</ResourceDictionary>
