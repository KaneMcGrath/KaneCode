<Application x:Class="KaneCode.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:KaneCode"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Index 0: MLib base theme (swapped at runtime by ThemeManager) -->
                <ResourceDictionary Source="pack://application:,,,/MLib;component/Themes/DarkTheme.xaml" />

                <!-- Index 1: App extended brushes (swapped at runtime by ThemeManager) -->
                <ResourceDictionary Source="/KaneCode;component/Themes/DarkBrushes.xaml" />

                <!-- Index 2+: Constant dictionaries (never swapped) -->
                <ResourceDictionary Source="Themes/WindowStyles.xaml" />
                <ResourceDictionary Source="Themes/ControlColours.xaml" />
                <ResourceDictionary Source="Themes/MenuStyles.xaml" />
                <ResourceDictionary Source="Themes/ControlStyles.xaml" />
                <ResourceDictionary Source="Themes/AvalonDockStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
