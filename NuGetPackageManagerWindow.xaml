<Window x:Class="KaneCode.NuGetPackageManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NuGet Package Manager"
        Width="800" Height="550"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource WindowForeground}">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: Project selector + connection status -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Project:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource PanelForeground}" />

                <ComboBox x:Name="ProjectComboBox" Grid.Column="1"
                          DisplayMemberPath="DisplayName"
                          MinWidth="300"
                          Height="24"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"
                          SelectionChanged="ProjectComboBox_SelectionChanged" />

                <!-- Connection status indicator -->
                <Border x:Name="ConnectionStatusIndicator" Grid.Column="2"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        Padding="6,3"
                        CornerRadius="3"
                        Background="{DynamicResource DiagnosticInfoForeground}">
                    <TextBlock x:Name="ConnectionStatusText" FontSize="11"
                               Foreground="White" VerticalAlignment="Center" />
                </Border>

                <!-- Package count -->
                <TextBlock Grid.Column="3" x:Name="PackageCountText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PanelForeground}"
                           FontSize="12" />
            </Grid>
        </Border>

        <!-- Tab header -->
        <TabControl Grid.Row="1" x:Name="MainTabControl"
                    Background="{DynamicResource TabStripBackground}"
                    BorderThickness="0"
                    Height="28"
                    SelectedIndex="0"
                    SelectionChanged="MainTabControl_SelectionChanged">
            <TabItem Header="Browse" />
            <TabItem Header="Installed" />
            <TabItem Header="Updates" />
        </TabControl>

        <!-- Content area -->
        <Grid Grid.Row="2" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Left panel: search + package list -->
            <Border Grid.Column="0" Background="{DynamicResource PanelBackground}" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Search box -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchTextBox" Grid.Column="0"
                                 Height="24"
                                 Padding="4,0"
                                 KeyDown="SearchTextBox_KeyDown" />
                        <Button x:Name="SearchButton" Grid.Column="1"
                                Content="Search" Width="70" Margin="4,0,0,0"
                                Padding="6,2"
                                Click="SearchButton_Click" />
                    </Grid>

                    <!-- Include prerelease checkbox -->
                    <CheckBox x:Name="IncludePrereleaseCheckBox" Grid.Row="1"
                              Content="Include prerelease"
                              Margin="0,0,0,4"
                              Foreground="{DynamicResource PanelForeground}"
                              FontSize="11"
                              Checked="SearchOptions_Changed"
                              Unchecked="SearchOptions_Changed" />

                    <!-- Loading progress bar -->
                    <ProgressBar x:Name="LoadingProgressBar" Grid.Row="2"
                                 Height="3"
                                 Margin="0,0,0,4"
                                 IsIndeterminate="True"
                                 Visibility="Collapsed" />

                    <!-- Package list -->
                    <ListBox x:Name="PackageListBox" Grid.Row="4"
                             ItemsSource="{Binding}"
                             DisplayMemberPath="DisplayText"
                             Background="{DynamicResource ControlBackground}"
                             Foreground="{DynamicResource MenuForeground}"
                             BorderThickness="1"
                             SelectionChanged="PackageListBox_SelectionChanged"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="4,3" />
                                <Setter Property="Foreground" Value="{DynamicResource MenuForeground}" />
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource TreeViewItemSelectedBackground}" />
                                        <Setter Property="Foreground" Value="{DynamicResource TreeViewItemSelectedForeground}" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource TreeViewItemMouseOverBackground}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Separator -->
            <Border Grid.Column="1" Background="{DynamicResource SplitterBackground}" />

            <!-- Right panel: package details -->
            <Border Grid.Column="2" Background="{DynamicResource WindowBackground}" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="PackageDetailPanel">
                        <!-- Package ID -->
                        <TextBlock x:Name="DetailPackageId" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource WindowForeground}"
                                   TextWrapping="Wrap" />

                        <!-- Version info -->
                        <TextBlock x:Name="DetailVersion" FontSize="13"
                                   Foreground="{DynamicResource PanelForeground}"
                                   Margin="0,2,0,8" />

                        <!-- Authors -->
                        <TextBlock x:Name="DetailAuthors" FontSize="11"
                                   Foreground="{DynamicResource PanelForeground}"
                                   Margin="0,0,0,4" />

                        <!-- Downloads -->
                        <TextBlock x:Name="DetailDownloads" FontSize="11"
                                   Foreground="{DynamicResource PanelForeground}"
                                   Margin="0,0,0,8" />

                        <!-- Description -->
                        <TextBlock x:Name="DetailDescription" FontSize="12"
                                   Foreground="{DynamicResource WindowForeground}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <!-- Tags -->
                        <TextBlock x:Name="DetailTags" FontSize="11"
                                   Foreground="{DynamicResource PanelForeground}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <!-- Links -->
                        <StackPanel x:Name="DetailLinks" Orientation="Horizontal"
                                    Margin="0,0,0,12">
                            <TextBlock x:Name="DetailProjectUrl" FontSize="11"
                                       Foreground="{DynamicResource DiagnosticInfoForeground}"
                                       Cursor="Hand"
                                       TextDecorations="Underline"
                                       MouseLeftButtonUp="DetailProjectUrl_MouseLeftButtonUp"
                                       Visibility="Collapsed" />
                        </StackPanel>

                        <!-- Version selector for install -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Version:" VerticalAlignment="Center"
                                       Foreground="{DynamicResource PanelForeground}"
                                       Margin="0,0,6,0" />
                            <ComboBox x:Name="VersionComboBox" Width="180" Height="24"
                                      SelectionChanged="VersionComboBox_SelectionChanged" />
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="InstallButton"
                                    Content="Install"
                                    Padding="12,5" Margin="0,0,8,0"
                                    Click="InstallButton_Click" />
                            <Button x:Name="UpdateButton"
                                    Content="Update"
                                    Padding="12,5" Margin="0,0,8,0"
                                    Click="UpdateButton_Click" />
                            <Button x:Name="UninstallButton"
                                    Content="Uninstall"
                                    Padding="12,5" Margin="0,0,8,0"
                                    Click="UninstallButton_Click" />
                        </StackPanel>

                        <!-- Status message in detail panel -->
                        <TextBlock x:Name="DetailStatus" FontSize="12"
                                   Foreground="{DynamicResource DiagnosticInfoForeground}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="{DynamicResource StatusBarBackground}" Padding="8,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusBarText" Grid.Column="0"
                           Foreground="{DynamicResource StatusBarForeground}"
                           FontSize="11"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
